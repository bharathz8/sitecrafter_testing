  "external_libraries": {
    "gsap_scrolltrigger": {
      "crawl_url": "https://gsap.com/docs/v3/Plugins/ScrollTrigger/",
      "fetch_method": "tavily",
      "description": "GSAP ScrollTrigger connects scroll position to animations. Enables scrubbing, pinning, snapping, and scroll-driven camera paths. Free as of 2025.",
      "keywords": ["scroll", "scrolltrigger", "cinematic scroll", "pin", "scrub", "parallax", "scroll animation", "reveal", "on scroll"],
      "codesnippet": "import { gsap } from 'gsap';\nimport { ScrollTrigger } from 'gsap/ScrollTrigger';\n\ngsap.registerPlugin(ScrollTrigger);\n\n// Basic scroll-triggered animation\ngsap.to('.box', {\n  scrollTrigger: {\n    trigger: '.box',\n    start: 'top center',\n    end: 'bottom top',\n    scrub: 1,\n    pin: true,\n    markers: false\n  },\n  x: 500,\n  rotation: 360\n});\n\n// Timeline pinned section (storytelling scroll)\nconst tl = gsap.timeline({\n  scrollTrigger: {\n    trigger: '.section',\n    start: 'top top',\n    end: '+=1000',\n    scrub: true,\n    pin: true\n  }\n});\ntl.to('.title', { opacity: 1, y: 0 })\n  .to('.image', { scale: 1.2 })\n  .to('.text', { opacity: 1 });\n\n// Horizontal scroll\ngsap.to('.wrapper', {\n  xPercent: -100,\n  scrollTrigger: {\n    trigger: '.container',\n    pin: true,\n    scrub: true,\n    end: '+=1000'\n  }\n});\n\n// Callbacks\nScrollTrigger.create({\n  trigger: '.element',\n  start: 'top 80%',\n  onEnter: ({ progress, direction, isActive }) => console.log('entered'),\n  onLeave: () => console.log('left'),\n  onEnterBack: () => console.log('entered back'),\n  onUpdate: self => console.log('progress:', self.progress)\n});",
      "dependencies": "npm install gsap"
    },

    "lenis": {
      "crawl_url": "https://github.com/darkroomengineering/lenis",
      "fetch_method": "tavily",
      "description": "Lenis is a lightweight smooth scroll library that synchronizes native scroll with requestAnimationFrame, keeping CSS sticky, IntersectionObserver, and GSAP ScrollTrigger all working correctly.",
      "keywords": ["smooth scroll", "lenis", "scroll sync", "butter scroll", "inertia scroll", "lerp scroll"],
      "codesnippet": "import Lenis from 'lenis';\nimport { gsap } from 'gsap';\nimport { ScrollTrigger } from 'gsap/ScrollTrigger';\n\n// Basic Lenis setup\nconst lenis = new Lenis({\n  duration: 1.2,        // scroll duration multiplier\n  easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n  orientation: 'vertical',\n  gestureOrientation: 'vertical',\n  smoothWheel: true,\n  wheelMultiplier: 1,\n  touchMultiplier: 2,\n  infinite: false\n});\n\n// Standalone RAF loop\nfunction raf(time) {\n  lenis.raf(time);\n  requestAnimationFrame(raf);\n}\nrequestAnimationFrame(raf);\n\n// GSAP ScrollTrigger integration (recommended)\nlenis.on('scroll', ScrollTrigger.update);\ngsap.ticker.add((time) => {\n  lenis.raf(time * 1000);\n});\ngsap.ticker.lagSmoothing(0);\n\n// Listen to scroll events\nlenis.on('scroll', (e) => {\n  console.log(e.scroll, e.progress, e.velocity, e.direction);\n});\n\n// Control methods\nlenis.stop();     // pause scrolling\nlenis.start();    // resume scrolling\nlenis.scrollTo('#target', { offset: -100, duration: 2 });\n\n// Required CSS\n// html.lenis, html.lenis body { height: auto; }\n// .lenis.lenis-smooth { scroll-behavior: auto !important; }\n// .lenis.lenis-stopped { overflow: hidden; }",
      "dependencies": "npm install lenis"
    },

    "rapier": {
      "crawl_url": "https://rapier.rs/docs/user_guides/javascript/getting_started_js/",
      "fetch_method": "tavily",
      "description": "Rapier is a high-performance Rust-based physics engine compiled to WASM. Handles rigid bodies, colliders, joints, gravity, forces, and collision events. Used with Three.js by syncing physics body positions to mesh positions each frame.",
      "keywords": ["physics", "rapier", "rigid body", "collision", "gravity", "bounce", "fall", "physics engine", "simulate", "forces", "joints"],
      "codesnippet": "import('@dimforge/rapier3d-compat').then(RAPIER => {\n  RAPIER.init().then(() => {\n\n    // 1. Create world with gravity\n    const gravity = { x: 0.0, y: -9.81, z: 0.0 };\n    const world = new RAPIER.World(gravity);\n\n    // 2. Static ground collider (no rigid body = fixed)\n    const groundDesc = RAPIER.ColliderDesc.cuboid(10.0, 0.1, 10.0);\n    world.createCollider(groundDesc);\n\n    // 3. Dynamic rigid body\n    const rigidBodyDesc = RAPIER.RigidBodyDesc.dynamic()\n      .setTranslation(0.0, 5.0, 0.0)\n      .setLinearDamping(0.5)\n      .setGravityScale(1.0);\n    const rigidBody = world.createRigidBody(rigidBodyDesc);\n\n    // 4. Attach collider to rigid body\n    const colliderDesc = RAPIER.ColliderDesc.cuboid(0.5, 0.5, 0.5)\n      .setFriction(0.8)\n      .setRestitution(0.3)\n      .setDensity(1.0);\n    world.createCollider(colliderDesc, rigidBody);\n\n    // 5. Three.js mesh (separate from physics body)\n    const mesh = new THREE.Mesh(\n      new THREE.BoxGeometry(1, 1, 1),\n      new THREE.MeshStandardMaterial({ color: 0xff6600 })\n    );\n    scene.add(mesh);\n\n    // 6. Sync loop — copy physics position to mesh every frame\n    function animate() {\n      world.step(); // advance physics\n      const pos = rigidBody.translation();\n      const rot = rigidBody.rotation();\n      mesh.position.set(pos.x, pos.y, pos.z);\n      mesh.quaternion.set(rot.x, rot.y, rot.z, rot.w);\n    }\n\n    // Collider shapes: cuboid, ball, capsule, cylinder, trimesh, heightfield\n    // Body types: dynamic(), fixed(), kinematicPositionBased(), kinematicVelocityBased()\n    // Apply forces: rigidBody.applyImpulse({ x:0, y:10, z:0 }, true);\n    // Apply torque:  rigidBody.applyTorqueImpulse({ x:0, y:1, z:0 }, true);\n    // Set velocity:  rigidBody.setLinvel({ x:1, y:3, z:0 }, true);\n  });\n});",
      "dependencies": "npm install @dimforge/rapier3d-compat"
    },

    "howler": {
      "crawl_url": "https://github.com/goldfire/howler.js#documentation",
      "fetch_method": "tavily",
      "description": "Howler.js is a full-featured spatial audio library. Supports positional 3D audio (Web Audio API), audio sprites, streaming, fade in/out, and automatic codec detection. Far more capable than Three.js's built-in Audio for immersive experiences.",
      "keywords": ["audio", "sound", "music", "spatial audio", "3d sound", "howler", "positional audio", "sound effects", "background music", "audio sprite"],
      "codesnippet": "import { Howl, Howler } from 'howler';\n\n// Basic sound\nconst sound = new Howl({\n  src: ['sound.webm', 'sound.mp3'],\n  volume: 0.5,\n  loop: false,\n  autoplay: false,\n  onend: () => console.log('Finished!')\n});\nsound.play();\nsound.pause();\nsound.stop();\nsound.fade(0, 1, 2000); // fade from 0 to 1 over 2s\n\n// 3D Positional audio\nconst spatial = new Howl({\n  src: ['ambient.webm', 'ambient.mp3'],\n  loop: true,\n  volume: 1.0,\n  pannerAttr: {\n    panningModel: 'HRTF',\n    refDistance: 1,\n    rolloffFactor: 1,\n    distanceModel: 'inverse'\n  }\n});\nspatial.pos(x, y, z);       // set sound position in 3D space\nspatial.play();\n\n// Update listener position from Three.js camera each frame\nHowler.pos(\n  camera.position.x,\n  camera.position.y,\n  camera.position.z\n);\nHowler.orientation(\n  forward.x, forward.y, forward.z, // look direction\n  up.x, up.y, up.z                  // up vector\n);\n\n// Audio sprites (multiple sounds in one file)\nconst sprite = new Howl({\n  src: ['sprites.webm', 'sprites.mp3'],\n  sprite: {\n    footstep: [0, 350],\n    jump:     [500, 300],\n    land:     [1000, 450]\n  }\n});\nsprite.play('footstep');\nsprite.play('jump');",
      "dependencies": "npm install howler"
    }
  },

